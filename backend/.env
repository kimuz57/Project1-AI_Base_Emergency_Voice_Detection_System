# Guardian AI Backend — Environment Variables
# ─────────────────────────────────────────────

# MQTT Broker (mosquitto local หรือ cloud)
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPIC=voice/audio/#

# LINE Notify Token
# สร้างได้ที่: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=YOUR_LINE_NOTIFY_TOKEN_HERE

# Database
DB_PATH=./guardian.db

# WebSocket Port (สำหรับ Dashboard real-time)
WS_PORT=8081

# HTTP API Port
HTTP_PORT=3001

# Audio Settings
SAMPLE_RATE=16000
AUDIO_BUFFER_SECONDS=2
AUDIO_DIR=./audio_files

# Python Path (เปลี่ยนถ้า python ไม่ได้อยู่ใน PATH)
PYTHON_CMD=python

# Alert threshold (confidence ขั้นต่ำก่อนแจ้งเตือน)
ALERT_THRESHOLD=0.7
